# Tono backend env vars. Copy to .env for local dev; on Railway / Fly
# these are set via the platform's secret store.

# --- LLM provider ------------------------------------------------------------
# "mock" | "openai" | "anthropic"
TONO_PROVIDER=mock

# When TONO_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# When TONO_PROVIDER=anthropic:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Rate limit --------------------------------------------------------------
FREE_DAILY_LIMIT=10

# --- Stripe (optional — server runs fine without it for /api/analyze) --------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Public URL Stripe will redirect back to. Defaults to the request's host
# when unset (good for dev).
PUBLIC_BASE_URL=

# --- Persistence -------------------------------------------------------------
# SQLite file path. Use a mounted volume in production.
TONO_DB_PATH=./tono.db

# --- Slack (optional — /slack/install, /slack/command) -----------------------
# Create a Slack app at https://api.slack.com/apps and enable slash commands.
# Redirect URL: https://<your-host>/slack/oauth
# Slash command: /tono  request_url: https://<your-host>/slack/command
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# --- Abuse caps --------------------------------------------------------------
# Maximum draft length in characters (default 2000).
DRAFT_MAX_CHARS=2000
# Per-IP requests per minute before a 429 is returned (default 20).
IP_RATE_LIMIT_PER_MIN=20

# --- Promo / coupon codes (optional) -----------------------------------------
# Secret header value for POST /admin/coupon/create. Set to a strong random
# string in production; leave empty to disable the admin endpoint.
TONO_ADMIN_SECRET=

# --- Misc --------------------------------------------------------------------
TONO_LOG_LEVEL=INFO
