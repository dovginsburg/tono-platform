# Copy this file to .env.local and supply values from the dedicated Tono project.
# Never reuse a ParentScript or other product project ref.
TONO_DEPLOYMENT_ENV=staging
TONO_SUPABASE_STAGING_PROJECT_REF=replace_with_staging_ref
TONO_SUPABASE_PRODUCTION_PROJECT_REF=replace_with_production_ref
NEXT_PUBLIC_SUPABASE_URL=https://replace_with_staging_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_staging_anon_key
