# URL of the shared Tono backend (apps/backend). Local dev default matches
# `uvicorn Backend.server:app --port 8765` run from apps/backend.
NEXT_PUBLIC_TONO_API_URL=http://localhost:8765

# Sign in with Google/Apple (components/SocialSignIn.tsx). Leave empty to
# hide that button entirely — nothing breaks without them, passkeys still
# work as a full standalone sign-in method.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_APPLE_CLIENT_ID=
