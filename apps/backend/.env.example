# Tono backend env vars. Copy to .env for local dev; on Railway / Fly
# these are set via the platform's secret store.

# --- LLM provider ------------------------------------------------------------
# "mock" | "openai" | "anthropic"
TONO_PROVIDER=mock

# When TONO_PROVIDER=openai:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# When TONO_PROVIDER=anthropic:
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Rate limit --------------------------------------------------------------
FREE_DAILY_LIMIT=10

# --- Stripe (optional — server runs fine without it for /api/analyze) --------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Public URL Stripe will redirect back to. Defaults to the request's host
# when unset (good for dev).
PUBLIC_BASE_URL=

# --- Persistence -------------------------------------------------------------
# Postgres connection string. Railway's Postgres plugin injects this
# automatically as `postgres://...` — the server rewrites that to the
# `postgresql+asyncpg://` scheme SQLAlchemy's async engine needs, so you can
# paste Railway's value here verbatim. `docker-compose up` sets this to the
# `db` service for local dev; if you're not using docker-compose, point it
# at a local Postgres 16+ instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tono_dev

# Redis connection string. Backs short-lived, single-use state (WebAuthn
# challenges, Slack/IP rate-limit windows) that needs to be shared across
# worker processes, unlike a plain in-memory dict. Railway's Redis plugin
# injects this automatically; `docker-compose up` sets it to the `redis`
# service.
REDIS_URL=redis://localhost:6379/0

# --- Account sign-in (optional — POST /v1/auth/apple, /v1/auth/google) -------
# Without these set, sign-in returns 503; devices keep working anonymously.
# APPLE_CLIENT_ID: your Sign in with Apple Services ID (the `aud` claim on
#   the identity token the client sends — for a native iOS app this is
#   usually the app's own bundle ID, not a separate Services ID).
APPLE_CLIENT_ID=
# GOOGLE_CLIENT_ID: OAuth client ID from Google Cloud Console (the `aud`
#   claim on the ID token).
GOOGLE_CLIENT_ID=

# APPLE_JWKS_URL / APPLE_ISSUER / GOOGLE_JWKS_URL / GOOGLE_ISSUERS: leave
# unset in every real environment — they default to Apple's/Google's real
# key endpoints. They exist ONLY so
# Backend/scripts/oauth_test_harness.py can redirect verification to a
# local fake JWKS server for testing the verification code itself without
# needing production client IDs or network access to either provider. If
# you ever see one of these set to something other than the real provider
# URL outside that harness, that's a misconfiguration.

# --- Passkeys / WebAuthn (optional — the mechanism behind "sign in with
# Face ID / Touch ID / Windows Hello / fingerprint" on web + desktop) -------
# WEBAUTHN_RP_ID: your domain, no scheme/port (e.g. "tonoit.com"). Must
#   exactly match (or be a registrable-domain suffix of) the origin the
#   client runs on — "localhost" for local dev.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Tono
# WEBAUTHN_ORIGIN: comma-separated exact origins allowed to complete a
#   ceremony (scheme + host + port). Must match what the browser sends.
WEBAUTHN_ORIGIN=http://localhost:3300

# --- Slack (optional — /slack/install, /slack/command) -----------------------
# Create a Slack app at https://api.slack.com/apps and enable slash commands.
# Redirect URL: https://<your-host>/slack/oauth
# Slash command: /tono  request_url: https://<your-host>/slack/command
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# --- Abuse caps --------------------------------------------------------------
# Maximum draft length in characters (default 2000).
DRAFT_MAX_CHARS=2000
# Per-IP requests per minute before a 429 is returned (default 20).
IP_RATE_LIMIT_PER_MIN=20

# --- Promo / coupon codes (optional) -----------------------------------------
# Secret header value for POST /admin/coupon/create. Set to a strong random
# string in production; leave empty to disable the admin endpoint.
TONO_ADMIN_SECRET=

# --- Misc --------------------------------------------------------------------
TONO_LOG_LEVEL=INFO
